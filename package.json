{
  "name": "nova-bot",
  "version": "1.0.0",
  "description": "Local AI desktop assistant - LM Studio, SQLite memory",
  "author": "Your Name",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "npm run build && node scripts/build-release.js"
  },
  "build": {
    "appId": "com.novabot.app",
    "productName": "Nova Bot",
    "asar": false,
    "directories": {
      "output": "release-out"
    },
    "files": [
      "package.json",
      "dist/**",
      "electron/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "README.md",
        "to": "README.md"
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "app-builder-bin": "^5.0.0-alpha.10",
    "better-sqlite3": "^11.6.0",
    "express": "^4.21.0",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "vite": "^6.0.1",
    "wait-on": "^8.0.1"
  }
}
